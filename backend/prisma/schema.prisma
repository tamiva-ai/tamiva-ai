generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectType {
  logo
  video
  carousel
  full_package
}

enum ProjectStatus {
  draft
  queued
  generating
  rendering
  ready
  failed
}

enum JobStage {
  hero_image
  storyboard
  video_prompt
  render
  composite
  copy_generation
}

enum JobProvider {
  veo_3_1
  omni_flash
  gpt_image
  elevenlabs
  suno
  claude
}

enum JobStatus {
  queued
  running
  succeeded
  failed
}

model User {
  id             String   @id @default(uuid())
  email          String   @unique
  fullName       String?
  phone          String?  @unique
  passwordHash   String?
  phoneVerified  Boolean  @default(false)
  authProvider   String   @default("email")
  // v36: removed creditsBalance — tier (free|pro) is the single source of
  // truth for entitlement. tierExpiresAt drives automatic downgrade so
  // monthly Pro actually lapses (was S2.15).
  tier          String   @default("free")
  tierUpdatedAt DateTime?
  tierExpiresAt DateTime?
  createdAt      DateTime @default(now())

  businessProfiles BusinessProfile[]
  paymentOrders    PaymentOrder[]
}

model BusinessProfile {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  name            String
  industry        String
  tagline         String?
  tone            String?
  brandColors     Json?
  targetAudience  String?
  logoStylePrefs  Json?
  palettePreference String?
  fontPreference    String?
  createdAt       DateTime @default(now())

  ambassadors BrandAmbassador[]
  projects    Project[]
}

model BrandAmbassador {
  id                String   @id @default(uuid())
  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id])
  photoUrls         String[]
  angleLabels       String[]
  createdAt         DateTime @default(now())
}

model Project {
  id                String        @id @default(uuid())
  businessProfileId String
  businessProfile   BusinessProfile @relation(fields: [businessProfileId], references: [id])
  type              ProjectType
  status            ProjectStatus @default(draft)
  creditsUsed       Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  jobs   GenerationJob[]
  assets Asset[]
}

model GenerationJob {
  id           String      @id @default(uuid())
  projectId    String
  project      Project     @relation(fields: [projectId], references: [id])
  stage        JobStage
  provider     JobProvider
  status       JobStatus   @default(queued)
  inputPayload Json
  outputUrl    String?
  error        String?
  retries      Int         @default(0)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

enum AssetType {
  logo_variant
  video_final
  carousel_slide
}

model Asset {
  id          String    @id @default(uuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id])
  type        AssetType
  slideIndex  Int?
  url         String
  overlayData Json?
  createdAt   DateTime  @default(now())
}

// ---------------------------------------------------------------------
// v36: Payment reconciliation (S1.1). Each Razorpay order we create
// lives here. Both the webhook and the client /verify call upsert on
// providerOrderId so duplicate webhook deliveries + the client verify
// call never double-grant Pro.
// ---------------------------------------------------------------------
enum PaymentOrderStatus {
  created
  paid
  failed
  expired
}

model PaymentOrder {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])
  providerOrderId   String   @unique
  provider          String   @default("razorpay")
  amountPaise       Int
  currency          String   @default("INR")
  // v37: which plan this order is for. Nullable because pre-v37 orders
  // didn't track this; treat missing as "pro" in the verify / webhook
  // paths so existing rows keep working.
  plan              String?
  status            PaymentOrderStatus @default(created)
  providerPaymentId String?
  verifiedAt        DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
}

// ---------------------------------------------------------------------
// v36: Idempotency keys (S3.18). Clients attach Idempotency-Key to
// mutating requests and we cache the response keyed by (userId, key).
// Safe to retry on network drops without creating duplicate rows
// (signup, business profile, payments).
// ---------------------------------------------------------------------
model IdempotencyKey {
  id         String   @id @default(uuid())
  userId     String
  key        String
  method     String
  path       String
  statusCode Int
  response   Json
  createdAt  DateTime @default(now())

  @@unique([userId, key])
  @@index([createdAt])
}

// ---------------------------------------------------------------------
// v36: Password reset codes (S1.5). Live in the DB (not in-memory) so
// they survive backend redeploys on Railway. TTL via expiresAt; cooldown
// via createdAt; attempts tracked; consumed flag so a successful reset
// can never be replayed.
// ---------------------------------------------------------------------
model PasswordResetCode {
  id         String   @id @default(uuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  attempts   Int      @default(0)
  consumed   Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

// ---------------------------------------------------------------------
// v38: Provider call logs. Captures every outbound HTTP exchange with
// OpenAI / Gemini (and any future provider) for admin debugging at
// https://api.tamiva.in/admin/logs. 3-day retention; pruned by the
// worker on boot and every 6h.
//
// `requestSummary` carries the input (prompt, refs, params).
// `responseSummary` carries the output (asset URLs, status, body).
// Image b64 is captured - we want live debugging fidelity - but the
// admin UI renders a truncated preview with a "Show full" toggle.
// ---------------------------------------------------------------------
model ProviderCall {
  id              String   @id @default(uuid())
  operation       String   // e.g. "openai.generateImage", "openai.downloadRaw", "gemini.generateVideo", "gemini.pollVideoOperation"
  provider        String   // "openai" | "gemini"
  projectId       String?
  jobId           String?
  status          Int?     // HTTP status. null = network/exception.
  durationMs      Int
  errorKind       String?  // "timeout" | "rate_limit" | "bad_status" | "decode" | "network" | null
  requestSummary  Json     // captured input
  responseSummary Json?    // captured output (null on failure)
  createdAt       DateTime @default(now())

  @@index([createdAt])
  @@index([projectId])
  @@index([operation])
  @@index([status])
}
